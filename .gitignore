.AppleDouble
.LSOverride
Icon
# and thumbnails
._*

# People have already very handy .gitignore templates for Python projects.
# Below is this one here: https://github.com/github/gitignore/blob/main/Python.gitignore
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

